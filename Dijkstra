import networkx as nx
import matplotlib.pyplot as plt

# Create Graph
G = nx.Graph()

# User Input
n = int(input("Enter number of vertices: "))

print("Enter vertex names:")
vertices = input().split()

m = int(input("Enter number of edges: "))

print("\nEnter edges in the format: Vertex1 Vertex2 Weight")

for i in range(m):
    u, v, w = input(f"Edge {i+1}: ").split()
    G.add_edge(u, v, weight=int(w))

# Source Vertex
source = input("\nEnter source vertex: ")

# Dijkstra Algorithm
distance = nx.single_source_dijkstra_path_length(G, source)

# Print Shortest Distances
print("\nShortest Distance from", source)

for vertex in distance:
    print(source, "->", vertex, "=", distance[vertex])

# Draw Graph
pos = nx.spring_layout(G, seed=42)

nx.draw(G, pos,
        with_labels=True,
        node_color="lightblue",
        node_size=700)

edge_labels = nx.get_edge_attributes(G, "weight")
nx.draw_networkx_edge_labels(G, pos, edge_labels=edge_labels)

plt.title("Weighted Graph")
plt.show()
